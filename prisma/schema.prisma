generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Schedule {
  id           String   @id @default(uuid())
  class_code   String   @db.VarChar(10)
  class_name   String   @db.VarChar(10)
  subject_code String   @db.VarChar(10)
  teacher_nik  String   @db.VarChar(20)
  teacher_name String   @db.VarChar(100)
  date         DateTime
  jam_ke       Int
  time_start   String
  time_end     String

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}